#!/usr/bin/env python3
# ==============================================================================
# FILE        : tests/stubs/socat
# ==============================================================================
# Synopsis    : Mock socat binary for testing
# Description : Simulates a socat process that listens on a port and stays
#               alive until killed. Used by integration tests when real socat
#               is not installed.
#
# Behavior    : Writes PID to stdout, sleeps indefinitely.
#               Responds to SIGTERM/SIGINT by exiting cleanly.
#
# Usage       : chmod +x tests/stubs/socat
#               PATH=tests/stubs:$PATH socat-manager listen --port 8080
#
# Notes       : Recognizes -V (prints a stub version banner and exits);
#               otherwise blocks until signaled, simulating a live listener.
# Version     : 1.0.1
# ==============================================================================

"""Mock socat stub for testing."""

import os
import signal
import sys
import time


def _handle_term(signum, frame):
    """Exit cleanly on SIGTERM."""
    sys.exit(0)


def main():
    """Simulate a socat process."""
    signal.signal(signal.SIGTERM, _handle_term)
    signal.signal(signal.SIGINT, _handle_term)

    # If -V is passed, print version info and exit
    if "-V" in sys.argv:
        print("socat by Gerhard Rieger and contributors - see www.dest-unreach.org")
        print("socat version 1.8.0.0 (STUB)")
        sys.exit(0)

    # Otherwise, simulate a running socat process
    # Stay alive until killed
    try:
        while True:
            time.sleep(60)
    except (KeyboardInterrupt, SystemExit):
        sys.exit(0)


if __name__ == "__main__":
    main()
