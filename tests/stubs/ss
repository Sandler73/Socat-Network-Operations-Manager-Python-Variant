"""Mock ss stub for testing."""

import sys


def main():
    """Simulate ss output."""
    # Default: no listeners found (empty output)
    # Tests can set SS_MOCK_OUTPUT env var to control output
    import os
    mock_output = os.environ.get("SS_MOCK_OUTPUT", "")
    if mock_output:
        print(mock_output)
    else:
        print("State  Recv-Q  Send-Q   Local Address:Port   Peer Address:Port")
    sys.exit(0)


if __name__ == "__main__":
    main()
