# =============================================================================
# .gitignore — Socat Network Operations Manager (Python Variant)
# =============================================================================
# Excludes runtime artifacts, session data, logs, certificates, Python
# bytecode, virtual environments, and editor-specific files from version
# control. Only source code, documentation, configuration templates, and
# test source should be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime directories (created automatically by socat-manager)
# These contain ephemeral session data, logs, and generated certificates
# that are specific to each deployment and should never be committed.
# -----------------------------------------------------------------------------

# Session metadata files (contain PIDs, PGIDs, commands — deployment-specific)
sessions/
sessions/*.session
sessions/*.pid
sessions/*.stop
sessions/*.launching
sessions/.lock

# Log files (master logs, session logs, error logs, capture logs)
logs/
logs/*.log

# Auto-generated TLS certificates and private keys (tunnel mode)
# CRITICAL: runtime-generated private keys must NEVER be committed. The
# directory itself is deliberately NOT wholesale-ignored, so the committed
# example material (generator script, openssl config, README, and the clearly
# labeled throwaway pair) can be re-included at the end of this file. Anything
# generated at runtime still matches the patterns below and stays ignored.
certs/*.pem
certs/*.key
certs/*.crt

# Configuration directory (may contain deployment-specific port configs)
# NOTE: Template configs (e.g., ports.conf.example) SHOULD be committed.
conf/*.conf
!conf/ports.conf.example

# Databases and audit stores (SQLite and its write-ahead sidecar files)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Python bytecode and packaging artifacts
# -----------------------------------------------------------------------------

# Bytecode cache
__pycache__/
*.pyc
*.pyo
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
*.whl
sdist/
wheels/

# pip
pip-log.txt
pip-delete-this-directory.txt

# Installer logs
install.log

# setuptools
*.egg-info/
.installed.cfg

# PyInstaller
*.manifest
*.spec

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------

venv/
.venv/
env/
.env/
ENV/
socat-manager-venv/

# Conda
*.conda
conda-meta/

# Pipenv
Pipfile.lock

# Poetry
poetry.lock

# -----------------------------------------------------------------------------
# Testing and coverage artifacts
# -----------------------------------------------------------------------------

# pytest
.pytest_cache/
tests/tmp/
tests/reports/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover

# tox
.tox/

# mypy
.mypy_cache/
dmypy.json
dmypy.txt

# ruff
.ruff_cache/

# Hypothesis (property-based testing)
.hypothesis/

# TAP output
*.tap

# -----------------------------------------------------------------------------
# IDE and editor artifacts
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains IDEs (PyCharm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
tags
*~

# Emacs
\#*\#
.#*
*.elc
auto-save-list
tramp
.projectile
*.org

# Atom
.atom/

# Jupyter
.ipynb_checkpoints
*.ipynb

# Spyder
.spyderproject
.spyproject

# -----------------------------------------------------------------------------
# OS artifacts
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# Linux
*~
*.swp
*.swo
*.swn
.nfs*
.directory

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
[Dd]esktop.ini

# -----------------------------------------------------------------------------
# Build and distribution artifacts
# Release tarballs, checksums, and dist output are build products.
# Generated by `make dist` — not source.
# -----------------------------------------------------------------------------

dist/
*.tar.gz
*.tar.bz2
*.zip
*.7z
*.sha256

# -----------------------------------------------------------------------------
# Security-sensitive files that must NEVER be committed
# (Belt-and-suspenders with certs/ exclusion above)
# -----------------------------------------------------------------------------

# Private keys and credentials
*.key
*.pem
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.secret
*.password
*.credentials
*.token

# Environment files with secrets
.env
.env.local
.env.*.local
.envrc

# Shell history
.bash_history
.zsh_history
.python_history

# -----------------------------------------------------------------------------
# Temporary and backup files
# -----------------------------------------------------------------------------

*.tmp
*.temp
*.bak
*.orig
*.backup
*.old
*.rej
*.patch

# Node.js (if any tooling uses npm)
node_modules/
package-lock.json
yarn.lock

# -----------------------------------------------------------------------------
# Committed example material (MUST be last so it overrides the broad *.key /
# *.pem / certs/*.* rules above). These are documentation and test aids only.
# The throwaway certificate and key are self-signed, expendable, and explicitly
# labeled — they must never be used to protect real traffic.
# -----------------------------------------------------------------------------
!certs/README.md
!certs/*.cnf
!certs/*.sh
!certs/example-do-not-use.crt
!certs/example-do-not-use.key
