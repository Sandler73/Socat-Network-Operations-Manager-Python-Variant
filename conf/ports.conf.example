# ==============================================================================
# FILE        : ports.conf.example
# ==============================================================================
# Synopsis    : Example batch listener configuration file
# Description : One port per line. Lines starting with # are comments.
#               Empty lines are ignored. Invalid ports are skipped with
#               a warning. Use with: socat-manager batch --file ports.conf
# Version     : 1.0.2
# ==============================================================================

# Common service ports (requires root/sudo for ports < 1024)
# 21
# 22
# 23
# 25
# 80
# 443

# High-numbered listener ports (no root required)
8080
8081
8082
8443
9090
